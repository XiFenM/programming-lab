{
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "explicit",
    "source.organizeImports.ruff": "explicit"
  },
  "files.associations": {
    "*.cu": "cuda-cpp",
    "*.cuh": "cuda-cpp"
  },
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/__pycache__": true
  },
  "files.watcherExclude": {
    "**/build/**": true,
    "**/target/**": true
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "python.defaultInterpreterPath": "/home/coder/.venvs/programming-lab/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests/python"],
  "python.testing.unittestEnabled": false,
  "basedpyright.analysis.typeCheckingMode": "strict",
  "ruff.nativeServer": "on",
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--compile-commands-dir=build/debug",
    "--completion-style=detailed",
    "--header-insertion=iwyu"
  ],
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": false,
  "cmake.configurePreset": "debug",
  "cmake.buildPreset": "debug",
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": [
    "--workspace",
    "--all-targets",
    "--locked"
  ],
  "rust-analyzer.cargo.allFeatures": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true
  },
  "[cuda-cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true
  }
}
