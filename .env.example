# Copy this file to .env and replace the IDs with `id -u` and `id -g` from
# the host. Compose reads this file while building the non-root container user.
COMPOSE_PROJECT_NAME=programming-lab
LOCAL_UID=1000
LOCAL_GID=1000

# Use "all" or a comma-separated GPU index/UUID list such as "0" or "0,1".
NVIDIA_VISIBLE_DEVICES=all

# v2rayA Lite sidecar. The Web UI is exposed only on the host loopback.
V2RAYA_IMAGE=mzz2017/v2raya:latest
V2RAYA_WEB_BIND_ADDRESS=127.0.0.1
V2RAYA_WEB_PORT=2017
V2RAYA_LOG_LEVEL=info
CODEX_HTTP_PROXY=http://127.0.0.1:20171
CODEX_SOCKS_PROXY=socks5h://127.0.0.1:20170
CODEX_NO_PROXY=localhost,127.0.0.1

# Mainland China mirrors. These values are passed to Docker build and runtime.
UBUNTU_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
UBUNTU_PORTS_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu-ports
NVIDIA_APT_MIRROR=https://developer.download.nvidia.cn/compute/cuda/repos
PYPI_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_CONCURRENT_DOWNLOADS=4
NVM_NODEJS_ORG_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/nodejs-release
RUSTUP_DIST_SERVER=https://mirrors.tuna.tsinghua.edu.cn/rustup
RUSTUP_UPDATE_ROOT=https://mirrors.tuna.tsinghua.edu.cn/rustup/rustup
