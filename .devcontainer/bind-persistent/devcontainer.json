{
  "name": "Programming Lab: bind + persistent",
  "dockerComposeFile": [
    "../../compose.yaml",
    "../../compose.gpu-legacy.yaml",
    "../../compose.bind.yaml",
    "../../compose.persist.yaml"
  ],
  "runServices": ["dev", "proxy"],
  "service": "dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "coder",
  "remoteEnv": {
    "HTTP_PROXY": "${containerEnv:V2RAYA_HTTP_PROXY}",
    "HTTPS_PROXY": "${containerEnv:V2RAYA_HTTP_PROXY}",
    "ALL_PROXY": "${containerEnv:V2RAYA_SOCKS_PROXY}",
    "NO_PROXY": "${containerEnv:V2RAYA_NO_PROXY}",
    "http_proxy": "${containerEnv:V2RAYA_HTTP_PROXY}",
    "https_proxy": "${containerEnv:V2RAYA_HTTP_PROXY}",
    "all_proxy": "${containerEnv:V2RAYA_SOCKS_PROXY}",
    "no_proxy": "${containerEnv:V2RAYA_NO_PROXY}"
  },
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "postCreateCommand": "bash scripts/init-env.sh",
  "waitFor": "postCreateCommand",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb",
    "gpu": true
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "detachhead.basedpyright",
        "editorconfig.editorconfig",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools",
        "nvidia.nsight-vscode-edition",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "timonwong.shellcheck",
        "vadimcn.vscode-lldb"
      ]
    }
  }
}
