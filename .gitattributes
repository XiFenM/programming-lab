# Normalize every text file to LF in both the Git index and the working tree.
# `text=auto` leaves files detected as binary untouched, while `eol=lf`
# overrides core.autocrlf on every platform.
* text=auto eol=lf

# Explicitly classify repository-native source, configuration, and documentation
# formats so checkout behavior never depends on Git's text-detection heuristic.
.gitattributes text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cmake text eol=lf
*.cpp text eol=lf
*.cu text eol=lf
*.cuh text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.mk text eol=lf
*.ps1 text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
.env* text eol=lf
Dockerfile* text eol=lf
Makefile* text eol=lf
docker/bashrc text eol=lf
